# Monorepo-wide ignores for local deps, generated output, caches, and machine state.
# Keep source, lockfiles, Dockerfiles, and example env files committed.

# Local tool state
.codex
.codex/

# Dependencies
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/versions/

# Frontend build output
**/.next/
**/out/
**/dist/
**/build/
**/coverage/
**/.turbo/
**/.cache/
*.tsbuildinfo
next-env.d.ts

# Java / JVM build output
**/target/
**/.gradle/
*.class

# Logs and runtime artifacts
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.pid
*.pid.lock

# Environment and secrets
.env
.env.local
.env.*.local
.env.*
!.env.example
!.env*.example

# Deployment / platform local state
.vercel/

# Editor / IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.factorypath
.settings/
.apt_generated/
.springBeans
.sts4-cache/

# OS files
.DS_Store
Thumbs.db

# Certificates / keys
*.pem
